unit uUtils;

interface

uses Vcl.Forms, System.SysUtils;

procedure abreMenu(menu,tela:string);
procedure abreConsulta(tela:string);


implementation

uses uConsulta;



procedure abreMenu(menu,tela:string);
begin
  if menu = 'Consulta' then
    abreConsulta(tela);

end;

procedure abreConsulta(tela:string);
begin
  Application.CreateForm(TfConsulta, fConsulta);
  fConsulta._tela := tela;
  fConsulta.ShowModal;
  fConsulta.free;
end;

end.
