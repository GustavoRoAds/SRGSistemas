unit uUtils;

interface

uses Vcl.Forms, System.SysUtils;

procedure abreMenu(menu,tela:string);
procedure abreConsulta;


implementation

uses uConsulta;



procedure abreMenu(menu,tela:string);
begin
  if menu = 'Consulta' then
    abreConsulta;

end;

procedure abreConsulta;
begin
  Application.CreateForm(TfConsulta, fConsulta);
  fConsulta.ShowModal;
  fConsulta.free;
end;

end.
