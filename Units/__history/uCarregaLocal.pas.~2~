unit uCarregaLocal;

interface

uses System.IOUtils, System.IniFiles, System.SysUtils;

procedure carregandoLocal;

implementation

uses BaseModule;

const
  arq_ini = 'configuracao.ini';


procedure carregandoLocal;
var
  aqIni: TIniFile;
begin
  pathAppdata := TPath.GetHomePath;

  aqIni := TIniFile.Create(pathAppdata + arq_ini);

end;

end.
