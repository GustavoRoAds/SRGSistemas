unit uCarregaLocal;

interface

uses System.IOUtils, System.IniFiles, System.SysUtils;

function criaLocal:TIniFile;

implementation

uses BaseModule;

const
  arq_ini = 'configuracao.ini';


function criaLocal:TIniFile;
var
  aqIni: TIniFile;
begin
  pathAppdata := TPath.GetHomePath;
  result := TIniFile.Create(pathAppdata + arq_ini);
end;

end.
