unit uUtils;

interface

uses Vcl.Forms, System.SysUtils;;

procedure abreMenu(menu:string);
procedure abreConsulta;


implementation

uses uConsulta;



procedure abreMenu(menu:string);
begin
  if menu = 'Consulta' then
    abreConsulta;

end;

procedure abreConsulta;
begin
  Application.CreateForm(TfConsulta, fConsulta);
  fConsulta.ShowModal;
  fConsulta.freeAndNil;
  fConsulta.Release;

end;

end.
