unit uSRGSistemas;

interface

uses
  Winapi.Windows, Winapi.Messages, System.SysUtils, System.Variants, System.Classes, Vcl.Graphics,
  Vcl.Controls, Vcl.Forms, Vcl.Dialogs, Vcl.ExtCtrls, Vcl.WinXCtrls,
  Vcl.Imaging.pngimage, Vcl.Buttons, Vcl.StdCtrls, system.IniFiles,
  Vcl.Imaging.jpeg, Vcl.Menus;

type
  TfSRGSistemas = class(TForm)
    SplitMenu: TSplitView;
    Panel1: TPanel;
    Image2: TImage;
    Panel3: TPanel;
    Image3: TImage;
    Panel4: TPanel;
    srCliente: TImage;
    pnMenu: TPanel;
    Image1: TImage;
    Panel2: TPanel;
    Panel5: TPanel;
    Panel6: TPanel;
    Panel7: TPanel;
    SpeedButton1: TSpeedButton;
    SpeedButton2: TSpeedButton;
    SpeedButton3: TSpeedButton;
    Panel8: TPanel;
    Panel9: TPanel;
    Panel10: TPanel;
    Image4: TImage;
    lbUser: TLabel;
    MainMenu1: TMainMenu;
    Cadastro1: TMenuItem;
    Faturamento1: TMenuItem;
    Outros1: TMenuItem;
    Atalhos1: TMenuItem;
    FlowPanel: TFlowPanel;
    procedure srClienteClick(Sender: TObject);
    procedure FormCreate(Sender: TObject);
    procedure FormKeyDown(Sender: TObject; var Key: Word; Shift: TShiftState);
    procedure Image1Click(Sender: TObject);
    procedure SpeedButton1Click(Sender: TObject);
    procedure FormShow(Sender: TObject);
    procedure Atalhos1Click(Sender: TObject);
  private
    _atalho:string;
    procedure carregaEmpresa;
    procedure abreAtalho(Sender: TObject);
    { Private declarations }
  public
    { Public declarations }
  end;

var
  fSRGSistemas: TfSRGSistemas;

implementation

{$R *.dfm}

uses uCliente, estrutura_banco, uDM, uUtils, uCarregaLocal;

procedure TfSRGSistemas.FormCreate(Sender: TObject);
var
  cQry:string;
begin
  DM.oQry.close;
  DM.oQry.SQL.Clear;
  DM.oQry.Connection := DM.oCon;

  cQry := ' CREATE TABLE IF NOT EXISTS cliente( ';
  cQry := cQry + ' codigo INTEGER PRIMARY KEY AUTOINCREMENT, ';
  cQry := cQry + ' nome TEXT NOT NULL, ';
  cQry := cQry + ' cpf TEXT NOT NULL, ';
  cQry := cQry + ' cnpj TEXT NOT NULL, ';
  cQry := cQry + ' rg TEXT, ';
  cQry := cQry + ' cep TEXT, ';
  cQry := cQry + ' endereco TEXT, ';
  cQry := cQry + ' numero TEXT, ';
  cQry := cQry + ' bairro TEXT, ';
  cQry := cQry + ' telefone TEXT, ';
  cQry := cQry + ' celular TEXT, ';
  cQry := cQry + ' observacao TEXT ';
  cQry := cQry+  ');';

  DM.oQry.SQL.Clear;
  DM.oQry.SQL.Add(cQry);
  DM.oQry.ExecSQL();
end;

procedure TfSRGSistemas.FormKeyDown(Sender: TObject; var Key: Word;
  Shift: TShiftState);
begin
  if key = VK_ESCAPE then
    fSRGSistemas.close;
end;

procedure TfSRGSistemas.FormShow(Sender: TObject);
begin
  carregaEmpresa();
end;

procedure TfSRGSistemas.Atalhos1Click(Sender: TObject);
begin
  abreMenu('Atalho');
end;

procedure TfSRGSistemas.abreAtalho(Sender: TObject);

begin
  abreMenu((Sender as TPanel).Name);
end;

procedure TfSRGSistemas.carregaEmpresa();
var
  cQry: string;
  ini: TIniFile;
  pnl: TPanel;
  lbl: TLabel;
  img: TImage;
begin
  ini := getIni;
  lbUser.Caption := ini.ReadString('LOCAL', 'nomeUser', '');

  DM.oQry.Close;
  DM.oQry.SQL.Clear;

  DM.oQry.SQL.Add('SELECT * from atalho');
  DM.oQry.Open();

  if DM.oQry.RecordCount > 0 then
  begin
    DM.oQry.First;
    while not DM.oQry.Eof do
    begin
      if DM.oQry.FieldByName('ativo').AsString = 'S' then
      begin
        // Panel (bot緌)
        pnl := TPanel.Create(FlowPanel);
        pnl.Parent := FlowPanel;
        pnl.Width := 130;
        pnl.Height := 130;
        pnl.BevelOuter := bvNone;
        pnl.ParentBackground := False;
        pnl.Color := $00634E38;
        pnl.Cursor := crHandPoint;
        pnl.Margins.SetBounds(10,10,10,10);
        pnl.Name := DM.oQry.FieldByName('nome').AsString;
        pnl.Caption := '';
        pnl.OnClick := abreAtalho;

        img := TImage.Create(pnl);
        img.Parent := pnl;
        img.Align := alTop;
        img.Center := true;
        img.AutoSize := true;
        img.Width := 128;
        img.Height := 128;
        img.Picture.LoadFromFile(DM.oQry.FieldByName('caminhoImg').AsString);

        // Label (texto)
        lbl := TLabel.Create(pnl);
        lbl.Parent := pnl;
        lbl.Caption := DM.oQry.FieldByName('nome').AsString;
        lbl.Align := alBottom;
        lbl.Alignment := taCenter;
        lbl.Font.Color := clwhite;
        lbl.Font.Size := 12;
        lbl.Layout := tlCenter;
      end;

      DM.oQry.Next;
    end;

  end;
end;

procedure TfSRGSistemas.Image1Click(Sender: TObject);
begin
  SplitMenu.Opened := not SplitMenu.Opened;
end;

procedure TfSRGSistemas.SpeedButton1Click(Sender: TObject);
begin
  abreMenu('Cliente');
end;

procedure TfSRGSistemas.srClienteClick(Sender: TObject);
begin
  abreMenu('Cliente');
end;

end.
